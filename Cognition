# -----------------------------
# FIT BAYESIAN MODELS
# -----------------------------
rows = []
skipped = []

REQ_COLS_BASE = [
    ID_COL,
    "y_winsor",
    "Time_z",
    "Age_baseline",
    "Gender_baseline",
    "YrsOfEd_baseline",
    "ALPS_baseline_z",
    "CP_frac_baseline_z",
    "WMH_frac_baseline_z",
    "BG_PVS_frac_baseline_z",
    "PIB_FS_DVR_FLR_baseline_z",
]

for outcome in OUTCOMES:
    if outcome not in df.columns:
        skipped.append({"outcome": outcome, "reason": "missing column"})
        continue

    print("=" * 60)
    print("Fitting outcome:", outcome)

    cols = [
        ID_COL, SESSION_COL, "TimeYears", "Time_z", outcome,
        "Age_baseline", "Gender_baseline", "YrsOfEd_baseline",
        "ALPS_baseline_z", "CP_frac_baseline_z", "WMH_frac_baseline_z",
        "BG_PVS_frac_baseline_z", "PIB_FS_DVR_FLR_baseline_z",
    ]
    d = df[cols].copy()

    d[outcome] = safe_numeric(d[outcome])
    d["TimeYears"] = safe_numeric(d["TimeYears"])
    d["Time_z"] = safe_numeric(d["Time_z"])
    d["Age_baseline"] = safe_numeric(d["Age_baseline"])
    d["Gender_baseline"] = safe_numeric(d["Gender_baseline"])
    d["YrsOfEd_baseline"] = safe_numeric(d["YrsOfEd_baseline"])

    for c in [
        "ALPS_baseline_z",
        "CP_frac_baseline_z",
        "WMH_frac_baseline_z",
        "BG_PVS_frac_baseline_z",
        "PIB_FS_DVR_FLR_baseline_z",
    ]:
        d[c] = safe_numeric(d[c])

    d["y_winsor"] = np.nan
    for s in [BASELINE_SESSION, FOLLOWUP_SESSION]:
        idx = d[SESSION_COL] == s
        d.loc[idx, "y_winsor"] = winsorize_series(
            d.loc[idx, outcome], WINSOR_P_LOW, WINSOR_P_HIGH
        )

    dd = d.dropna(subset=REQ_COLS_BASE).copy()

    n_rows = dd.shape[0]
    n_sub = dd[ID_COL].nunique()
    if n_rows < 40 or n_sub < 25:
        skipped.append({
            "outcome": outcome,
            "reason": "too few rows/subjects after model-wise dropna",
            "n_rows": int(n_rows),
            "n_subjects": int(n_sub),
        })
        continue

    y_sd = dd["y_winsor"].std(ddof=0)
    if pd.isna(y_sd) or y_sd == 0:
        skipped.append({
            "outcome": outcome,
            "reason": "zero variance after winsorization",
        })
        continue

    # Preserve the original pre-standardized cognitive scale.
    # Winsorize within session, but do not z-score the outcome again.
    dd["y_model"] = dd["y_winsor"]

    dd["Time_x_ALPS"] = dd["Time_z"] * dd["ALPS_baseline_z"]
    dd["Time_x_CP"] = dd["Time_z"] * dd["CP_frac_baseline_z"]
    dd["Time_x_WMH"] = dd["Time_z"] * dd["WMH_frac_baseline_z"]
    dd["Time_x_BG_PVS"] = dd["Time_z"] * dd["BG_PVS_frac_baseline_z"]
    dd["Time_x_PIB"] = dd["Time_z"] * dd["PIB_FS_DVR_FLR_baseline_z"]

    dd[ID_COL] = dd[ID_COL].astype("category")
    subj_idx = dd[ID_COL].cat.codes.values
    n_subjects = dd[ID_COL].nunique()

    X = {
        "Intercept": np.ones(len(dd)),
        "Time_z": dd["Time_z"].values,
        "ALPS_baseline_z": dd["ALPS_baseline_z"].values,
        "CP_frac_baseline_z": dd["CP_frac_baseline_z"].values,
        "WMH_frac_baseline_z": dd["WMH_frac_baseline_z"].values,
        "BG_PVS_frac_baseline_z": dd["BG_PVS_frac_baseline_z"].values,
        "PIB_FS_DVR_FLR_baseline_z": dd["PIB_FS_DVR_FLR_baseline_z"].values,
        "Time_x_ALPS": dd["Time_x_ALPS"].values,
        "Time_x_CP": dd["Time_x_CP"].values,
        "Time_x_WMH": dd["Time_x_WMH"].values,
        "Time_x_BG_PVS": dd["Time_x_BG_PVS"].values,
        "Time_x_PIB": dd["Time_x_PIB"].values,
        "Age_baseline": dd["Age_baseline"].values,
        "Gender_baseline": dd["Gender_baseline"].values,
        "YrsOfEd_baseline": dd["YrsOfEd_baseline"].values,
    }

    y = dd["y_model"].values
    fam = get_family(outcome)

    try:
        with pm.Model() as model:
            coefs = {
                name: pm.Normal(f"beta_{name}", mu=0, sigma=1.5)
                for name in X
            }

            sigma_subject = pm.HalfNormal("sigma_subject", sigma=1)
            subj_offset = pm.Normal("subj_offset", mu=0, sigma=1, shape=n_subjects)
            subj_int = pm.Deterministic("subj_int", subj_offset * sigma_subject)

            sigma = pm.HalfNormal("sigma", sigma=1)

            mu = sum(coefs[name] * values for name, values in X.items())
            mu = mu + subj_int[subj_idx]

            pm.Normal("y_obs", mu=mu, sigma=sigma, observed=y)

            idata = pm.sample(
                draws=DRAWS,
                tune=TUNE,
                chains=CHAINS,
                cores=CORES,
                target_accept=TARGET_ACCEPT,
                random_seed=RANDOM_SEED,
                return_inferencedata=True,
                progressbar=True,
            )

        for term in PRIMARY_TERMS_FOR_FDR:
            vals = idata.posterior[f"beta_{term}"].values.ravel()
            hdi = az.hdi(vals, hdi_prob=0.95)

            rows.append({
                "outcome": outcome,
                "family": fam,
                "term": term,
                "beta": float(np.mean(vals)),
                "hdi_low": float(hdi[0]),
                "hdi_high": float(hdi[1]),
                "p_bayes_2s": float(posterior_p_two_sided(vals)),
                "n_rows": int(n_rows),
                "n_subjects": int(n_sub),
            })

    except Exception as e:
        skipped.append({
            "outcome": outcome,
            "reason": f"fit failed: {type(e).__name__}",
            "detail": str(e)[:250],
        })
        continue

    try:
        tmp = dd[[ID_COL, SESSION_COL, "TimeYears", "y_winsor"]].rename(columns={"y_winsor": outcome})
        plot_mean_over_time(tmp, outcome, FIGDIR / f"TRAJ_{outcome}.png")
    except Exception:
        pass


res = pd.DataFrame(rows)
skip_df = pd.DataFrame(skipped)



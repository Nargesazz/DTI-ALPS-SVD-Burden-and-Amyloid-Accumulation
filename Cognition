        df[f"{frac}_baseline_z"] = zscore(df[f"{frac}_baseline"])
    else:
        df[f"{frac}_baseline"] = np.nan
        df[f"{frac}_baseline_z"] = np.nan

pib_col = pick_first_existing(df, PIB_CANDIDATES)
